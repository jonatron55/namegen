{
  "configurations": [
    {
      "args": [
        "--count=25",
        "--constraint=suffix:false",
        "--constraint=title:false",
        "--constraint=firstname:P",
        "--constraint=surname:P"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "RUST_BACKTRACE",
          "value": "1"
        }
      ],
      "name": "Windows",
      "program": "${workspaceFolder}/target/debug/namegen.exe",
      "request": "launch",
      "stopAtEntry": false,
      "type": "cppvsdbg"
    }
  ]
}
